# Pytest API suite (restful-booker).
FROM python:3.12-slim

WORKDIR /app

# Install dependencies first for better layer caching.
COPY api-tests/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Copy the Python test sources.
COPY api-tests/ ./

# HTML report lands at /app/report.html (mount a host volume to collect it).
CMD ["python", "-m", "pytest"]
